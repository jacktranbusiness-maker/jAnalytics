# ---------------------------------------------------------------------------
# GA4 Analytics Dashboard - backend configuration
# Copy to `.env` and adjust. `.env` is gitignored.
# ---------------------------------------------------------------------------

# When true, the API serves deterministic mock data (no Google API calls).
# Set to false to use the real Google Analytics 4 Data API.
MOCK_MODE=true

# Websites shown in the dashboard. Keep this JSON on one line because the
# lightweight backend loader reads standard KEY=VALUE entries.
# Admin > Property Settings > Property ID
GA4_SITES_JSON=[{"id":"website-one","name":"Website One","domain":"example.com","property_id":"PROPERTY_ID_1","color":"#1a73e8"},{"id":"website-two","name":"Website Two","domain":"example.org","property_id":"PROPERTY_ID_2","color":"#34a853"}]

# Legacy single-property fallback. Leave blank when GA4_SITES_JSON is set.
GOOGLE_ANALYTICS_PROPERTY_ID=

# --- Credentials (only needed when MOCK_MODE=false). Pick ONE: ---
#
# A) Local / container: path to the service account JSON key file
#    (needs GA4 "Viewer" on the property).
GOOGLE_APPLICATION_CREDENTIALS=
#
# B) Serverless (Vercel, etc.): the service account key as inline JSON, or
#    base64-encoded JSON. Set this as an Environment Variable in the Vercel
#    dashboard -- do NOT commit it.
#    GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# Legacy single-property labels.
SITE_NAME=My Website
SITE_DOMAIN=example.com

# Realtime quota protection. Keep the last good snapshot available while a
# temporary Google Analytics quota window clears.
REALTIME_CACHE_TTL_SECONDS=60
REALTIME_STALE_TTL_SECONDS=3600

# Comma-separated list of allowed frontend origins (CORS).
# In production set this to your deployed frontend URL, e.g.
#   CORS_ORIGINS=https://janalytics.vercel.app
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
